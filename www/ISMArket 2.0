Content-Type: text/css
Content-Transfer-Encoding: binary
Content-Location: cid:css-2a002d65-8bfe-4e54-a0e4-2d132e3470b9@mhtml.blink

@charset "utf-8";

:root { --bg: #0a0a0a; --bg2: #111; --bg3: #1a1a1a; --bg4: #222; --gold: #E8A93D; --gold2: #f5c842; --gold3: rgba(232,169,61,.13); --green: #22c55e; --red: #ef4444; --blue: #3b82f6; --orange: #f97316; --text: #fff; --t2: rgba(255,255,255,.62); --t3: rgba(255,255,255,.28); --line: rgba(255,255,255,.08); --r: 14px; }

* { box-sizing: border-box; margin: 0px; padding: 0px; -webkit-tap-highlight-color: transparent; }

body { font-family: "Segoe UI", system-ui, sans-serif; background: var(--bg); color: var(--text); max-width: 430px; margin: 0px auto; min-height: 100vh; overflow-x: hidden; }

button, input, select, textarea { font-family: inherit; }

.h { display: none !important; }

.scr { display: none; min-height: 100vh; padding-bottom: 80px; animation: 0.2s ease 0s 1 normal none running fi; }

.scr.on { display: block; }

@keyframes fi { 
  0% { opacity: 0; transform: translateY(6px); }
  100% { opacity: 1; transform: translateY(0px); }
}

.tb { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; background: var(--bg); position: sticky; top: 0px; z-index: 30; border-bottom: 1px solid var(--line); }

.ib { width: 36px; height: 36px; border-radius: 10px; background: var(--bg3); border: 1px solid var(--line); color: var(--text); display: flex; align-items: center; justify-content: center; font-size: 15px; cursor: pointer; flex-shrink: 0; position: relative; }

.ibdot { position: absolute; top: -3px; right: -3px; width: 9px; height: 9px; background: var(--red); border-radius: 50%; border: 2px solid var(--bg); display: none; }

.ibdot.on { display: block; }

.bnav { position: fixed; bottom: 0px; left: 50%; transform: translateX(-50%); width: 100%; max-width: 430px; background: var(--bg2); border-top: 1px solid var(--line); display: flex; align-items: center; padding: 6px 0 calc(6px + env(safe-area-inset-bottom)); z-index: 50; }

.bn { flex: 1 1 0%; display: flex; flex-direction: column; align-items: center; gap: 2px; font-size: 10px; color: var(--t3); cursor: pointer; padding: 5px 0px; background: none; border: none; }

.bn .ni { font-size: 20px; }

.bn.on { color: var(--gold); }

.bnadd { width: 50px; height: 50px; border-radius: 50%; background: linear-gradient(135deg,var(--gold),var(--gold2)); border: none; font-size: 24px; color: rgb(0, 0, 0); display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: rgba(232, 169, 61, 0.5) 0px 4px 20px; flex-shrink: 0; font-weight: 700; }

.card { background: var(--bg2); border-radius: var(--r); padding: 14px; margin-bottom: 10px; border: 1px solid var(--line); }

.card-gold { background: linear-gradient(135deg, rgb(26, 21, 0), rgb(34, 28, 0)); border: 1px solid rgba(232, 169, 61, 0.3); }

.btn { display: flex; align-items: center; justify-content: center; gap: 7px; border: none; border-radius: 12px; padding: 13px 16px; font-size: 14px; font-weight: 700; cursor: pointer; width: 100%; margin-bottom: 9px; transition: opacity 0.15s; }

.btn:active { opacity: 0.8; }

.bg { background: linear-gradient(135deg,var(--gold),var(--gold2)); color: rgb(0, 0, 0); }

.bo { background: transparent; border: 1.5px solid var(--gold); color: var(--gold); }

.bd { background: var(--bg3); color: var(--text); }

.br { background: rgba(239, 68, 68, 0.15); color: var(--red); border: 1px solid rgba(239, 68, 68, 0.3); }

.bv { background: rgba(34, 197, 94, 0.15); color: var(--green); border: 1px solid rgba(34, 197, 94, 0.3); }

.bsm { width: auto; padding: 7px 13px; font-size: 12px; border-radius: 9px; margin-bottom: 0px; }

.f { margin-bottom: 13px; }

.f label { display: block; font-size: 11px; color: var(--t2); margin-bottom: 5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }

.f input, .f select, .f textarea { width: 100%; background: var(--bg3); border: 1.5px solid var(--line); border-radius: 11px; padding: 12px 14px; color: var(--text); font-size: 14px; outline: none; transition: border-color 0.2s; }

.f input:focus, .f select:focus, .f textarea:focus { border-color: var(--gold); }

.f input::placeholder, .f textarea::placeholder { color: var(--t3); }

.f select option { background: var(--bg3); }

.f-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

.pill { display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 700; }

.pg { background: rgba(34, 197, 94, 0.12); color: var(--green); }

.py { background: rgba(232, 169, 61, 0.15); color: var(--gold); }

.pr { background: rgba(239, 68, 68, 0.12); color: var(--red); }

.pb { background: rgba(59, 130, 246, 0.12); color: var(--blue); }

.pp { background: var(--bg3); color: var(--t2); }

.po { background: rgba(249, 115, 22, 0.12); color: var(--orange); }

.div { height: 1px; background: var(--line); margin: 13px 0px; }

.chips { display: flex; gap: 7px; padding: 10px 14px 4px; overflow-x: auto; scrollbar-width: none; }

.chips::-webkit-scrollbar { display: none; }

.chip { flex: 0 0 auto; padding: 7px 14px; border-radius: 999px; border: 1.5px solid var(--line); background: var(--bg2); font-size: 12.5px; font-weight: 600; color: var(--t2); white-space: nowrap; cursor: pointer; }

.chip.on { background: var(--gold); border-color: var(--gold); color: rgb(0, 0, 0); }

.mbg { position: fixed; inset: 0px; background: rgba(0, 0, 0, 0.75); z-index: 100; display: none; align-items: flex-end; justify-content: center; }

.mbg.on { display: flex; }

.modal { background: var(--bg2); width: 100%; max-width: 430px; border-radius: 22px 22px 0px 0px; max-height: 92vh; overflow-y: auto; padding: 18px 15px calc(22px + env(safe-area-inset-bottom)); animation: 0.22s ease 0s 1 normal none running su; }

@keyframes su { 
  0% { transform: translateY(40px); opacity: 0; }
  100% { transform: translateY(0px); opacity: 1; }
}

.mh { width: 36px; height: 4px; background: var(--line); border-radius: 99px; margin: 0px auto 15px; }

#toast { position: fixed; top: 16px; left: 50%; transform: translateX(-50%) translateY(-10px); z-index: 999; background: var(--bg3); border: 1px solid var(--line); color: var(--text); padding: 11px 20px; border-radius: 14px; font-size: 13px; font-weight: 600; display: none; max-width: 86%; text-align: center; box-shadow: rgba(0, 0, 0, 0.6) 0px 8px 32px; transition: transform 0.3s; }

#toast.show { transform: translateX(-50%) translateY(0px); }

.sinp { width: 100%; background: var(--bg3); border: 1.5px solid var(--line); border-radius: 13px; padding: 12px 14px 12px 42px; color: var(--text); font-size: 14px; outline: none; }

.sinp:focus { border-color: var(--gold); }

.sinp::placeholder { color: var(--t3); }

.swrap { position: relative; margin-bottom: 10px; }

.sico { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); font-size: 16px; color: var(--t2); }

.pgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 11px; padding: 6px 12px 18px; }

.pc { background: var(--bg2); border-radius: 14px; overflow: hidden; border: 1px solid var(--line); cursor: pointer; transition: transform 0.15s; }

.pc:active { transform: scale(0.97); }

.pthumb { height: 110px; display: flex; align-items: center; justify-content: center; font-size: 40px; background: var(--bg3); position: relative; }

.ctag { position: absolute; bottom: 5px; left: 5px; background: rgba(0, 0, 0, 0.7); color: var(--gold); font-size: 9px; font-weight: 700; padding: 3px 7px; border-radius: 6px; }

.ccert { position: absolute; top: 5px; right: 5px; background: rgba(34, 197, 94, 0.9); color: rgb(255, 255, 255); font-size: 8px; font-weight: 800; padding: 3px 7px; border-radius: 999px; }

.ptag { position: absolute; top: 5px; left: 5px; font-size: 8px; font-weight: 800; padding: 3px 7px; border-radius: 999px; }

.pbody { padding: 9px 10px 11px; }

.chat-msg { display: flex; flex-direction: column; margin-bottom: 12px; }

.chat-msg.me { align-items: flex-end; }

.them .chat-bubble { background: var(--bg3); border-radius: 4px 14px 14px; }

.me .chat-bubble { background: linear-gradient(135deg,var(--gold),var(--gold2)); color: rgb(0, 0, 0); border-radius: 14px 4px 14px 14px; }

.chat-bubble { max-width: 78%; padding: 10px 13px; border-radius: 14px; font-size: 13.5px; line-height: 1.45; }

.chat-time { font-size: 10px; color: var(--t3); margin-top: 3px; padding: 0px 4px; }

.chat-ir { display: flex; gap: 8px; padding: 10px 13px; background: var(--bg2); border-top: 1px solid var(--line); position: sticky; bottom: 0px; }

.cinp { flex: 1 1 0%; background: var(--bg3); border: 1px solid var(--line); border-radius: 22px; padding: 10px 14px; color: var(--text); font-size: 14px; outline: none; }

.csend { width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg,var(--gold),var(--gold2)); border: none; color: rgb(0, 0, 0); font-size: 17px; cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }

.tog { position: relative; width: 46px; height: 25px; flex-shrink: 0; }

.tog input { opacity: 0; width: 0px; height: 0px; }

.tsl { position: absolute; inset: 0px; background: var(--bg4); border-radius: 999px; cursor: pointer; transition: 0.3s; border: 1px solid var(--line); }

.tsl::before { content: ""; position: absolute; width: 19px; height: 19px; left: 3px; top: 3px; background: rgb(255, 255, 255); border-radius: 50%; transition: 0.3s; }

.tog input:checked + .tsl { background: var(--green); border-color: var(--green); }

.tog input:checked + .tsl::before { transform: translateX(21px); }

.vhero { background: linear-gradient(160deg, rgb(17, 17, 17), rgb(26, 26, 0)); padding: 18px 14px 16px; border-bottom: 1px solid var(--line); }

.sgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; margin-bottom: 12px; }

.scard { background: var(--bg2); border-radius: 12px; padding: 12px; border: 1px solid var(--line); }

.snum { font-size: 20px; font-weight: 800; }

.slbl { font-size: 10.5px; color: var(--t2); margin-top: 2px; }

.qa { display: flex; justify-content: space-around; padding: 10px 0px; }

.qai { display: flex; flex-direction: column; align-items: center; gap: 5px; cursor: pointer; }

.qaico { width: 52px; height: 52px; border-radius: 14px; background: var(--bg3); display: flex; align-items: center; justify-content: center; font-size: 22px; border: 1px solid var(--line); position: relative; }

.ava { width: 72px; height: 72px; border-radius: 50%; background: var(--bg3); display: flex; align-items: center; justify-content: center; font-size: 28px; border: 3px solid var(--gold); overflow: hidden; flex-shrink: 0; }

.li { display: flex; align-items: center; gap: 12px; padding: 12px 0px; border-bottom: 1px solid var(--line); cursor: pointer; }

.li-ico { width: 44px; height: 44px; border-radius: 12px; background: var(--bg3); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }

.pbar { background: var(--bg3); border-radius: 999px; height: 6px; overflow: hidden; margin-top: 4px; }

.pbar-fill { height: 100%; background: linear-gradient(90deg,var(--gold),var(--gold2)); border-radius: 999px; }

.flash-timer { font-size: 22px; font-weight: 800; color: var(--red); font-variant-numeric: tabular-nums; }

.loader { text-align: center; padding: 40px; color: var(--t2); }

.spin { display: inline-block; animation: 1s linear 0s infinite normal none running spin; }

@keyframes spin { 
  100% { transform: rotate(360deg); }
}
